# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
*.p8

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Playwright
/playwright-report/
/test-results/
/.playwright/

.vercel
.env*.local

# SQLite database files
*.db
*.db-wal
*.db-shm
# Quarantined corrupt DBs (created by sqlite.js recovery path) and their sidecars
*.db.corrupt.*
# Pre-restore safety copies (created by restore-db.js)
*.db.pre-restore.*
# Hot backups produced by backup-db.js
server/data/backups/

# Runtime JSON snapshots (legacy pre-SQLite). Live data is in *.db now;
# these files are kept ignored so a stray dev run doesn't re-track them.
server/data/*.json

# Claude Code per-project memory — never committed; lives locally only.
memory/
