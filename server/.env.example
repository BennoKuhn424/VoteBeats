PORT=3000
JWT_SECRET=your-secret-here

# AES-256-GCM key for pending_payments + bank details at-rest encryption.
# REQUIRED in production — server refuses to boot if NODE_ENV=production
# and this is unset. Any sufficiently long random string works (it's
# SHA-256-hashed to derive the 32-byte AES key).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Once set in production, do NOT rotate — existing bank-details rows will
# become unreadable. (pending_payments rows expire after 1h so they're safe.)
PAYMENT_ENCRYPTION_KEY=your-long-random-encryption-key

# Render Persistent Disk: set to your disk mount path (e.g. /data)
# Database is stored as DATA_DIR/speeldit.db (SQLite).
# Legacy votebeats.db is auto-renamed on startup.
# To migrate existing JSON data, run: node server/scripts/migrate-json-to-sqlite.js
# DATA_DIR=/data

# ── Database backups (server/scripts/backup-db.js) ───────────────────────────
# Run nightly via cron. See BACKUPS.md for full details.
# Number of local backups to keep in DATA_DIR/backups/ (default 14).
# BACKUP_RETENTION=14
# Off-disk copy for disaster recovery — REQUIRED in production. Local backups
# sit on the same disk as the DB, so a disk failure loses both. This shell
# command ships each verified backup off-box; {file}=absolute path, {base}=filename.
# Set the uploader's own credentials (AWS_ACCESS_KEY_ID, rclone.conf, …) too.
# BACKUP_REMOTE_CMD=aws s3 cp {file} s3://my-bucket/speeldit/
# BACKUP_REMOTE_CMD=rclone copy {file} r2:speeldit-backups/

# Music provider selection. Currently supported: "apple" (default).
# The configured provider determines which search/playback backend is used.
MUSIC_PROVIDER=apple

# Apple MusicKit (JWT from .p8 - recommended)
APPLE_TEAM_ID=[YOUR_TEAM_ID]
APPLE_KEY_ID=[YOUR_KEY_ID]
APPLE_MUSIC_KEY_PATH=[PATH_TO_FILE]
# Keep .p8 keys outside the repo directory.
# Example Windows: APPLE_MUSIC_KEY_PATH=C:\Users\YOU\.speeldit\keys\AuthKey_XXXXXXXX.p8
# Example Linux/Render: APPLE_MUSIC_KEY_PATH=/etc/secrets/AuthKey_XXXXXXXX.p8

# Legacy: pre-generated token (alternative to .p8)
# APPLE_MUSIC_DEVELOPER_TOKEN=eyJ...

# CORS – allowed origins for API and Socket.IO (comma-separated).
# In production at least one origin must be set via CORS_ORIGINS and/or PUBLIC_URL,
# otherwise the server will refuse to start. Values are trimmed; whitespace-only is rejected.
# Example: CORS_ORIGINS=https://yourapp.vercel.app,https://www.yourapp.com
CORS_ORIGINS=
PUBLIC_URL=http://localhost:5173

# ── Patron-payment provider (song-request checkouts for patrons) ─────────────
# Active provider: "yoco" (default). Add new providers under server/providers/payment/.
PATRON_PAYMENT_PROVIDER=yoco
# Yoco credentials — required when PATRON_PAYMENT_PROVIDER=yoco
YOCO_SECRET_KEY=sk_test_xxx
# Webhook signing (whsec_...) — https://developer.yoco.com/guides/online-payments/webhooks/verifying-the-events
# YOCO_WEBHOOK_SECRET=whsec_xxxxx

VENUE_EARNINGS_PERCENT=70
ADMIN_SECRET=your-admin-secret

# Platform owner dashboard (same login as venue login page → redirects to /owner)
# Generate hash: npm run hash-owner-password -- "your-secure-password"
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=

# ── Subscription provider (venue R599/month, 14-day trial) ───────────────────
# Active provider: "paystack" (default). Add new providers under server/providers/subscription/.
SUBSCRIPTION_PROVIDER=paystack
# Provider-neutral config (supersedes PAYSTACK_* below; PAYSTACK_* still read for backwards compat)
# SUBSCRIPTION_PLAN_CODE=PLN_xxxxxxxxxx
# SUBSCRIPTION_AMOUNT_ZAR=599
# SUBSCRIPTION_TRIAL_DAYS=14
# SUBSCRIPTION_ENFORCEMENT=lenient   # or "strict" to 402 for non-active subs

# Paystack credentials — required when SUBSCRIPTION_PROVIDER=paystack
# Dashboard: https://dashboard.paystack.com/#/settings/developers
# Test keys are safe in local dev; switch to pk_live_/sk_live_ before launch.
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
# Plan code from Paystack dashboard → Plans → your R599 monthly plan (format: PLN_xxxxxxxxxx)
PAYSTACK_PLAN_CODE=PLN_xxxxxxxxxx
# Webhook signing — Paystack dashboard → Settings → Webhooks. Verifies x-paystack-signature.
PAYSTACK_WEBHOOK_SECRET=
# Legacy aliases (read if the SUBSCRIPTION_* vars above are unset)
PAYSTACK_SUBSCRIPTION_AMOUNT_ZAR=599
PAYSTACK_TRIAL_DAYS=14
