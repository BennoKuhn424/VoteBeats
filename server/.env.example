PORT=3000
JWT_SECRET=your-secret-here

# Render Persistent Disk: set to your disk mount path (e.g. /data)
# Database is stored as DATA_DIR/votebeats.db (SQLite).
# To migrate existing JSON data, run: node server/scripts/migrate-json-to-sqlite.js
# DATA_DIR=/data

# Music provider selection. Currently supported: "apple" (default).
# The configured provider determines which search/playback backend is used.
MUSIC_PROVIDER=apple

# Apple MusicKit (JWT from .p8 - recommended)
APPLE_TEAM_ID=[YOUR_TEAM_ID]
APPLE_KEY_ID=[YOUR_KEY_ID]
APPLE_MUSIC_KEY_PATH=[PATH_TO_FILE]
# Example: APPLE_MUSIC_KEY_PATH=./AuthKey_XXXXXXXX.p8

# Legacy: pre-generated token (alternative to .p8)
# APPLE_MUSIC_DEVELOPER_TOKEN=eyJ...

# CORS – allowed origins for API and Socket.IO (comma-separated).
# In production at least one origin must be set via CORS_ORIGINS and/or PUBLIC_URL,
# otherwise the server will refuse to start. Values are trimmed; whitespace-only is rejected.
# Example: CORS_ORIGINS=https://yourapp.vercel.app,https://www.yourapp.com
CORS_ORIGINS=
PUBLIC_URL=http://localhost:5173
YOCO_SECRET_KEY=sk_test_xxx
# Webhook signing (whsec_...) — verify incoming webhooks; https://developer.yoco.com/guides/online-payments/webhooks/verifying-the-events
# YOCO_WEBHOOK_SECRET=whsec_xxxxx
VENUE_EARNINGS_PERCENT=80
ADMIN_SECRET=your-admin-secret

# Platform owner dashboard (same login as venue login page → redirects to /owner)
# Generate hash: npm run hash-owner-password -- "your-secure-password"
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=
